int sum(int data[], int n)
{
    int i;
    int total;
    i = 0;
    total = 0;
    while (i < n)
    {
        if (data[i] != 0)
            total = total + data[i] * 2;
        else
            total = total - 1;
        i = i + 1;
    }
    return total;
}

void main(void)
{
    int values[3];
    values[0] = 1;
    values[1] = 0;
    values[2] = 4;
    output(sum(values, 3));
}
