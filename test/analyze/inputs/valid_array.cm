int sum(int data[], int n)
{
    int i;
    int total;
    i = 0;
    total = 0;
    while (i < n)
    {
        total = total + data[i];
        i = i + 1;
    }
    return total;
}

int main(void)
{
    int values[3];
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    output(sum(values, 3));
    return 0;
}
